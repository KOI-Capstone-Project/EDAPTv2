# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=edapt_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=edapt_v2
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full async DSN consumed by SQLAlchemy (backend)
DATABASE_URL=postgresql+asyncpg://edapt_user:changeme@db:5432/edapt_v2

# ── FastAPI ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret
ENVIRONMENT=development          # development | production
LOG_LEVEL=info

# ── pgAdmin ──────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@edapt.local
PGADMIN_DEFAULT_PASSWORD=changeme

# ── Google Gemini ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── React (prefix REACT_APP_ so CRA exposes them) ────────
REACT_APP_API_BASE_URL=http://localhost:8000
