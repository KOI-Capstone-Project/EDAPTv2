# ── EDAPT v2 Backend — Development Image ──────────────────────────────────
# Slim image with hot-reload via uvicorn --reload.
# Source code is mounted as a volume — no COPY needed for dev.

FROM python:3.12-slim

WORKDIR /app

# System deps for asyncpg (libpq) and Scikit-Learn (build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies first (layer cached unless requirements change)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Source is mounted at runtime in dev — no COPY app here

EXPOSE 8000
