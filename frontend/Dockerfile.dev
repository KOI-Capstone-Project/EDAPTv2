# ── EDAPT v2 Frontend — Development Image ─────────────────────────────────
# Node + CRA dev server with hot-reload.
# Source mounted as volume at runtime.

FROM node:20-alpine

WORKDIR /app

# Install deps separately so layer is cached on package.json changes only
COPY package.json package-lock.json* ./
RUN npm ci

EXPOSE 3000

CMD ["npm", "start"]
